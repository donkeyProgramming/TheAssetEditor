<Window x:Class="CommonControls.BaseDialogs.NewPackFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="New Pack" 
        Width="380"
        Height="200"
        ResizeMode="NoResize"
        Style="{StaticResource CustomWindowStyle}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select pack type:" Margin="0,0,0,8" FontWeight="SemiBold"/>

        <RadioButton x:Name="GamePackRadio" Grid.Row="1" Content="Game Pack — in-memory pack file (.pack)" 
                     IsChecked="True" Margin="0,0,0,6" Checked="PackType_Changed"/>
        <RadioButton x:Name="FolderPackRadio" Grid.Row="2" Content="Folder Pack — mirrors a folder on disk" 
                     Margin="0,0,0,10" Checked="PackType_Changed"/>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <TextBox x:Name="NameTextBox" VerticalAlignment="Top" Height="24"
                     Visibility="Visible" KeyDown="Key_Down"/>
            <Button x:Name="BrowseFolderButton" Content="Browse folder..." 
                    VerticalAlignment="Top" Height="24"
                    Visibility="Collapsed" Click="BrowseFolder_Click"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="80" Content="OK" Margin="0,0,8,0" Click="Ok_Click"/>
            <Button Width="80" Content="Cancel" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
