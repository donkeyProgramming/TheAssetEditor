<UserControl x:Class="Editor.CampaignAnimationCreator.CampaignAnimationCreator.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:s="http://schemas.singulink.com/xaml"
             xmlns:loc="clr-namespace:Shared.Ui.Common;assembly=Shared.Ui"
             xmlns:local="clr-namespace:Editor.CampaignAnimationCreator.CampaignAnimationCreator"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel LastChildFill="False">
        <Label DockPanel.Dock="Top" Content="Campaign Animation Creator" FontSize="18" FontWeight="Bold" />

        <Grid DockPanel.Dock="Top" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <Label Grid.Column="0" Grid.Row="0" Content="{loc:Loc CampaignAnimationCreator.RootBone}" />
            <Label Grid.Column="1" Grid.Row="0" Content=":" />
            <ComboBox Grid.Column="2"
                      Grid.Row="0"
                      IsEditable="True"
                      IsTextSearchEnabled="False"
                      DisplayMemberPath="BoneName"
                      Text="{Binding ModelBoneList.Filter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                      ItemsSource="{Binding ModelBoneList.Values}"
                      SelectedItem="{Binding ModelBoneList.SelectedItem, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

            <Button Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Content="{loc:Loc CampaignAnimationCreator.Buttons.Convert}"
                    Margin="0,6,0,0"
                    Command="{Binding ConvertActionCommand}" />

            <Button Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Content="{loc:Loc CampaignAnimationCreator.Buttons.Save}"
                    Margin="0,6,0,0"
                    Command="{Binding SaveAnimationActionCommand}"
 />
        </Grid>
    </DockPanel>
</UserControl>