<Window x:Class="Editors.AnimatioReTarget.Editor.Saving.SaveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:System="clr-namespace:System;assembly=System.Runtime"
        xmlns:loc="clr-namespace:Shared.Ui.Common;assembly=Shared.Ui"
        mc:Ignorable="d"
         Style="{StaticResource CustomWindowStyle}"
        Title="{loc:Loc AnimationReTarget.Save.Title}" Height="450" Width="800">
    
    <Window.Resources>
        <System:Double x:Key="labelWidth">140</System:Double>
    </Window.Resources>


    <StackPanel>
        <DockPanel >
            <Label Content="{loc:Loc AnimationReTarget.Save.SavePrefix}" Width ="{StaticResource labelWidth}" DockPanel.Dock="Left"/>
            <Label Content=":" DockPanel.Dock="Left"/>
            <ComboBox Margin="2" DockPanel.Dock="Right" Width="60" 
                      ItemsSource="{Binding PossibleAnimationFormats, UpdateSourceTrigger=PropertyChanged}" 
                      SelectedItem="{Binding AnimationFormat, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
            <Label Content="{loc:Loc AnimationReTarget.Save.Format}" DockPanel.Dock="Right"/>
            <TextBox Text="{Binding SavePrefix, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" VerticalAlignment="Center" DockPanel.Dock="Left"/>
        </DockPanel>

        <DockPanel IsEnabled="False">
            <Label Content="{loc:Loc AnimationReTarget.Save.UseGeneratedSkeleton}" Width ="{StaticResource labelWidth}"/>
            <Label Content=":"/>
            <CheckBox VerticalContentAlignment="Center" IsChecked="{Binding UseScaledSkeletonName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
            <Button Content="{loc:Loc AnimationReTarget.Save.ExportScaledMesh}" Command="{Binding ExportScaledMesh}"  DockPanel.Dock="Right" Margin="2"/>
            <TextBox Text="{Binding ScaledSkeletonName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" VerticalAlignment="Center"/>
        </DockPanel>

        <DockPanel>
            <Button Click="SaveButtonClick">{loc:Loc AnimationReTarget.Save.Save}</Button>
        </DockPanel>
        <DockPanel IsEnabled="False">
            <Button>{loc:Loc AnimationReTarget.Save.BatchExport}</Button>
        </DockPanel>
        <DockPanel>
            <Button Click="CloseButtonClick">{loc:Loc AnimationReTarget.Save.Close}</Button>
        </DockPanel>
    </StackPanel>


</Window>
