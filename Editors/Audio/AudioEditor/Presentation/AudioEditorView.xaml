<UserControl 
    x:Class="Editors.Audio.AudioEditor.Presentation.AudioEditorView"
    x:Name="AudioEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:s="http://schemas.singulink.com/xaml" 
    xmlns:Local="clr-namespace:Editors.Audio.AudioEditor.Presentation"
    xmlns:AudioProjectExplorer="clr-namespace:Editors.Audio.AudioEditor.Presentation.AudioProjectExplorer"
    xmlns:AudioFilesExplorer="clr-namespace:Editors.Audio.AudioEditor.Presentation.AudioFilesExplorer"
    xmlns:AudioProjectEditor="clr-namespace:Editors.Audio.AudioEditor.Presentation.AudioProjectEditor"
    xmlns:Settings="clr-namespace:Editors.Audio.AudioEditor.Presentation.Settings"
    xmlns:AudioProjectViewer="clr-namespace:Editors.Audio.AudioEditor.Presentation.AudioProjectViewer"
    xmlns:WaveformVisualiser="clr-namespace:Editors.Audio.AudioEditor.Presentation.WaveformVisualiser" 
    xmlns:loc="clr-namespace:Shared.Ui.Common;assembly=Shared.Ui"
    d:DataContext="{d:DesignInstance Type=Local:AudioEditorViewModel}"
    mc:Ignorable="d" 
    d:DesignWidth="1200" d:DesignHeight="700">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition 
                Height="Auto"/>
            <RowDefinition 
                Height="Auto"/>
            <RowDefinition 
                Height="*"/>
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Grid.Column="0">
            
            <Grid.RowDefinitions>
                <RowDefinition 
                    Height="Auto"/>
            </Grid.RowDefinitions>

            <Menu 
                Grid.Row="0" 
                Margin="0, 5, 5, 0">
                <MenuItem 
                    Header="{loc:Loc AudioEditor.Menu.File}" 
                    HorizontalAlignment="Left">
                    <MenuItem 
                        Header="{loc:Loc AudioEditor.Menu.NewAudioProject}" 
                        Command="{Binding NewAudioProjectCommand}"/>
                    <MenuItem 
                        Header="{loc:Loc AudioEditor.Menu.OpenAudioProject}" 
                        Command="{Binding LoadAudioProjectCommand}"/>
                    <Separator/>
                    <MenuItem 
                        Header="{loc:Loc AudioEditor.Menu.SaveAudioProject}" 
                        Command="{Binding SaveAudioProjectCommand}"
                        IsEnabled="{Binding IsAudioProjectLoaded}"/>
                    <MenuItem 
                        Header="{loc:Loc AudioEditor.Menu.CompileAudioProject}" 
                        Command="{Binding CompileAudioProjectCommand}"
                        IsEnabled="{Binding IsAudioProjectLoaded}"/>
                    <Separator/>
                    <MenuItem 
                        Header="{loc:Loc AudioEditor.Menu.RefreshSourceIds}" 
                        Command="{Binding RefreshSourceIdsCommand}"
                        IsEnabled="{Binding IsAudioProjectLoaded}"/>
                </MenuItem>
                <MenuItem 
                    Header="{loc:Loc AudioEditor.Menu.Tools}" 
                    HorizontalAlignment="Left">
                    <MenuItem 
                        Header="{loc:Loc AudioEditor.Menu.DialogueEventMerger}" 
                        Command="{Binding OpenDialogueEventMergerCommand}"/>
                    <MenuItem
                        Header="{loc:Loc AudioEditor.Menu.AudioProjectMerger}"
                        Command="{Binding OpenAudioProjectMergerCommand}"/>
                    <MenuItem 
                        Header="{loc:Loc AudioEditor.Menu.AudioProjectConverter}" 
                        Command="{Binding OpenAudioProjectConverterCommand}"/>
                </MenuItem>
            </Menu>
        </Grid>

        <Border 
            Grid.Row="1" 
            Height="1" 
            Background="{DynamicResource App.Border}" 
            Margin="0, 5, 0, 0"/>

        <Grid 
            Grid.Row="2">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition 
                    Width="490"/>
                <ColumnDefinition 
                    Width="Auto"/>
                <ColumnDefinition 
                    Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid 
                Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition 
                        Height="*"/>
                </Grid.RowDefinitions>

                <Grid 
                    Grid.Row="1">

                    <Grid.RowDefinitions>
                        <RowDefinition 
                            Height="*"/>
                        <RowDefinition 
                            Height="Auto"/>
                        <RowDefinition 
                            Height="*"/>
                        <RowDefinition 
                            Height="Auto"/>
                        <RowDefinition 
                            Height="161"/>
                    </Grid.RowDefinitions>

                    <AudioProjectExplorer:AudioProjectExplorerView
                        Grid.Row="0"
                        Grid.Column="0"
                        DataContext="{Binding AudioProjectExplorerViewModel}"/>

                    <GridSplitter
                        Grid.Row="1"
                        Height="5"
                        Background="{DynamicResource App.Border}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch"
                        ResizeBehavior="PreviousAndNext"
                        ResizeDirection="Rows"/>

                    <AudioFilesExplorer:AudioFilesExplorerView 
                        Grid.Row="2"
                        Grid.Column="0"
                        DataContext="{Binding AudioFilesExplorerViewModel}"/>

                    <GridSplitter
                        Grid.Row="3"
                        Height="5"
                        Background="{DynamicResource App.Border}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch"
                        ResizeBehavior="PreviousAndNext"
                        ResizeDirection="Rows"/>

                    <WaveformVisualiser:WaveformVisualiserView 
                        Grid.Row="4"
                        Grid.Column="0"
                        DataContext="{Binding WaveformVisualiserViewModel}"/>
                </Grid>
            </Grid>

            <GridSplitter 
                Grid.Column="1" 
                Width="5" 
                Background="{DynamicResource App.Border}" 
                VerticalAlignment="Stretch" 
                HorizontalAlignment="Center"
                ResizeBehavior="PreviousAndNext" 
                ResizeDirection="Columns"/>
            
            <Grid 
                Grid.Column="2">

                <Grid.RowDefinitions>
                    <RowDefinition 
                        Height="Auto"/>
                    <RowDefinition 
                        Height="Auto"/>
                    <RowDefinition 
                        Height="Auto"/>
                    <RowDefinition 
                        Height="*"/>
                </Grid.RowDefinitions>

                <AudioProjectEditor:AudioProjectEditorView
                    Grid.Row="0"
                    Grid.Column="0"
                    DataContext="{Binding AudioProjectEditorViewModel}"/>

                <Border 
                    Grid.Row="1"
                    Height="5" 
                    Background="{DynamicResource App.Border}"
                    Visibility="{Binding IsSettingsBorderVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Settings:SettingsView 
                    Grid.Row="2"
                    Grid.Column="0"
                    DataContext="{Binding SettingsViewModel}"/>

                <AudioProjectViewer:AudioProjectViewerView 
                    Grid.Row="3"
                    Grid.Column="0"
                    DataContext="{Binding AudioProjectViewerViewModel}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>