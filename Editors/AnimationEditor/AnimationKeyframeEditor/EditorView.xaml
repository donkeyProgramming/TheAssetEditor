<UserControl x:Class="AnimationEditor.AnimationKeyframeEditor.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Shared.Ui.Common;assembly=Shared.Ui"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:s="http://schemas.singulink.com/xaml"
             xmlns:controls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="800">

    <UserControl.Resources>
        <controls:BooleanToVisibilityConverter x:Key="boolConv"/>
    </UserControl.Resources>

    <DockPanel LastChildFill="False">
        <Label  DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.Title}" FontSize="18" FontWeight="Bold"/>
        <Label  DockPanel.Dock="Top" FontSize="10">&lt;-- Drag the border to reveal the buttons text</Label>
        <Label  DockPanel.Dock="Top" FontSize="20" Foreground="Red" Visibility="{Binding IsDirty.Value, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource boolConv}}"  Content="{loc:Loc AnimationKeyframe.Warning}" />
        <Grid  DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0"  Content="{loc:Loc AnimationKeyframe.CurrentFrame}" FontSize="18" FontWeight="Bold"/>
            <Label Grid.Column="1" Content="{Binding CurrentFrameNumber.Value, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
            <Label Grid.Column="2" Content="{loc:Loc AnimationPlayer.Separator}" FontSize="18" FontWeight="Bold"/>
            <Label Grid.Column="3" Content="{Binding TotalFrameNumber.Value, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <DockPanel>
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.AllowSelectAnimroot}" IsChecked="{Binding AllowToSelectAnimRoot.Value, UpdateSourceTrigger=PropertyChanged}"  />
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.IncrementFrameCopy}" IsChecked="{Binding IncrementFrameAfterCopyOperation.Value, UpdateSourceTrigger=PropertyChanged}"  />
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.SelectPreviousBones}" IsChecked="{Binding AutoSelectPreviousBonesOnFrameChange.Value, UpdateSourceTrigger=PropertyChanged}"  />
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.EnableIK}" IsChecked="{Binding EnableInverseKinematics.Value, UpdateSourceTrigger=PropertyChanged}"  IsEnabled="false"  />
                <Label Content="{loc:Loc AnimationKeyframe.IKEndBone}" />
                <ComboBox  
                          IsEditable="True"
                          IsTextSearchEnabled="false"
                          DisplayMemberPath="BoneName"
                          Text="{Binding ModelBoneListForIKEndBone.Filter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                          ItemsSource="{Binding ModelBoneListForIKEndBone.Values}" 
                          IsEnabled="false" 
                          SelectedItem="{Binding ModelBoneListForIKEndBone.SelectedItem, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                <!-- "{Binding EnableInverseKinematics.Value}" -->
            </DockPanel>
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{loc:Loc AnimationKeyframe.FirstFrame}"  Click="{s:MethodBinding FirstFrame}" Margin="0,0,2,0"/>
            <Button Grid.Column="1" Content="{loc:Loc AnimationKeyframe.PrevFrame}"  Click="{s:MethodBinding PrevFrame}"  Margin="2,0,2,0"/>
            <Button Grid.Column="2" Content="{loc:Loc AnimationKeyframe.NextFrame}"  Click="{s:MethodBinding NextFrame}" Margin="2,0,0,0"/>
            <Button Grid.Column="3" Content="{loc:Loc AnimationKeyframe.LastFrame}"  Click="{s:MethodBinding LastFrame}" Margin="2,0,0,0"/>
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{loc:Loc AnimationKeyframe.DuplicateFrame}"  Click="{s:MethodBinding DuplicateFrame}" Margin="0,0,2,0"/>
            <Button Grid.Column="1" Content="{loc:Loc AnimationKeyframe.RemoveFrame}"  Click="{s:MethodBinding RemoveFrame}"  Margin="2,0,2,0"/>
            <Button Grid.Column="2" Content="{loc:Loc AnimationKeyframe.ResetPose}"  Click="{s:MethodBinding ResetPose}" Margin="2,0,0,0"/>
            <Button Grid.Column="3" Content="{loc:Loc AnimationKeyframe.UndoPose}"  Click="{s:MethodBinding UndoPose}" Margin="2,0,0,0"/>
        </Grid>


        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{loc:Loc AnimationKeyframe.Select}"  Click="{s:MethodBinding EnterSelectMode}" Margin="0,0,2,0"/>
            <Button Grid.Column="1" Content="{loc:Loc AnimationKeyframe.SelectPreviousBones2}"  Click="{s:MethodBinding SelectPreviousBones}" Margin="0,0,2,0"/>
            <Button Grid.Column="2" Content="{loc:Loc AnimationKeyframe.Move}"  Click="{s:MethodBinding EnterMoveMode}" Margin="0,0,2,0"/>
            <Button Grid.Column="3" Content="{loc:Loc AnimationKeyframe.Rotate}"  Click="{s:MethodBinding EnterRotateMode}"  Margin="2,0,2,0" />
            <Button Grid.Column="4" Content="{loc:Loc BoneMapping.Scale}"  Click="{s:MethodBinding EnterScaleMode}" Margin="2,0,0,0"/>
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <DockPanel>
                <Label Content="{loc:Loc AnimationKeyframe.PasteOperations}" />
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.PastePosition}" IsChecked="{Binding PastePosition.Value, UpdateSourceTrigger=PropertyChanged}"  />
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.PasteRotation}" IsChecked="{Binding PasteRotation.Value, UpdateSourceTrigger=PropertyChanged}"  />
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.PasteScale}" IsChecked="{Binding PasteScale.Value, UpdateSourceTrigger=PropertyChanged}"  />
            </DockPanel>
        </Grid>
        
        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{loc:Loc AnimationKeyframe.CopyPose}"  Click="{s:MethodBinding CopyCurrentPose}" Margin="2,0,0,0"/>
            <Button Grid.Column="1" Content="{loc:Loc AnimationKeyframe.PastePose}"  Click="{s:MethodBinding PasteIntoCurrentFrame}" Margin="2,0,0,0" />
            <Button Grid.Column="2" Content="{loc:Loc AnimationKeyframe.PastePoseSelected}"  Click="{s:MethodBinding PasteIntoSelectedCurrentNode}" Margin="2,0,0,0" />
            <Button Grid.Column="3" Content="{loc:Loc AnimationKeyframe.CopyPastePrevious}"  Click="{s:MethodBinding PastePreviousEditedNodesIntoCurrentPose}" Margin="2,0,0,0" />
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <DockPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>

                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" Content="{loc:Loc AnimationKeyframe.AnimationDuration}" />
                    <TextBox Grid.Column="1" PreviewTextInput="AnimationTextInputPreview" Text="{Binding FramesDurationInSeconds, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"></TextBox>
                    <Label Grid.Column="2" Content="{loc:Loc AnimationKeyframe.Seconds}" />
                    <Button Grid.Column="3"  Click="{s:MethodBinding ResetDuration}" Content="{loc:Loc Common.Reset}" />
                    <Button Grid.Column="4" Click="{s:MethodBinding ApplyDuration}" Content="{loc:Loc Kitbash.Bmi.Apply}" />
                </Grid>
            </DockPanel>

        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />
        </Grid>
        
        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <StackPanel>
                <Label>In range copy operations from other keyedframe editor window. </Label>
                <Label>It will copy current frame  and then paste in the destination animation up to desired length</Label>
            </StackPanel>
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel>
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.CopyMultipleFrames}" IsChecked="{Binding CopyMoreThanSingleFrame, UpdateSourceTrigger=PropertyChanged}"  />
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.DontWarnDifferentSkeletons}" IsChecked="{Binding DontWarnDifferentSkeletons.Value, UpdateSourceTrigger=PropertyChanged}"  />
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.DontWarnIncomingFrames}" IsChecked="{Binding DontWarnIncomingFramesBigger.Value, UpdateSourceTrigger=PropertyChanged}"  />
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.PasteUsingForm}" IsChecked="{Binding PasteUsingFormBelow, UpdateSourceTrigger=PropertyChanged}"  IsEnabled="{Binding CopyMoreThanSingleFrame}"/>
            </DockPanel>
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="{loc:Loc AnimationKeyframe.PasteLength}" />
            <TextBox Grid.Column="1" PreviewTextInput="FrameNrPreviewTextInput" TextChanged="FrameNrCantBeEmpty" IsEnabled="{Binding CopyMoreThanSingleFrame}" Text="{Binding FrameNrLength}"></TextBox>
            <Button Grid.Column="2" Content="{loc:Loc AnimationKeyframe.SetMax}"  Click="{s:MethodBinding SetFrameLengthMax}" Margin="2,0,0,0"/>
            <Button Grid.Column="3" Content="{loc:Loc AnimationKeyframe.FromClipboard}"  Click="{s:MethodBinding SetFrameLengthFromClipboard}" Margin="2,0,0,0"/>
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="{loc:Loc AnimationKeyframe.CopyPoseClipboard}"  Click="{s:MethodBinding CopyPoseInRangeToClipboard}" Margin="2,0,0,0"/>
            <Button Grid.Column="1" Content="{loc:Loc AnimationKeyframe.PastePoseClipboard}"  Click="{s:MethodBinding PastePoseInRangeFromClipboard}" Margin="2,0,0,0" />
            <Button Grid.Column="2" Content="{loc:Loc AnimationKeyframe.PastePoseSelectedClipboard}"  Click="{s:MethodBinding PasteIntoInRangeSelectedCurrentNodeFromClipboard}" Margin="2,0,0,0" />
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <StackPanel>
                <Label Content="{loc:Loc AnimationKeyframe.InterpolationHint1}" />
                <StackPanel Orientation="Horizontal">
                    <Label Content="{loc:Loc AnimationKeyframe.SelectedFrameA}" />
                    <Label Content="{Binding SelectedFrameAInterpolation.Value, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"></Label>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="{loc:Loc AnimationKeyframe.SelectedFrameB}" />
                    <Label Content="{Binding SelectedFrameBInterpolation.Value, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"></Label>
                </StackPanel>
                <StackPanel>
                    <Label>Drag the slider to manipulate the blending between frames,</Label>
                    <Label>to apply to the current frame, click apply interpolation on current frame.</Label>
                    <Label>To enable preview you need to select frame A and B.</Label>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{loc:Loc AnimationKeyframe.FirstFrame}"  Click="{s:MethodBinding FirstFrame}" Margin="0,0,2,0"/>
            <Button Grid.Column="1" Content="{loc:Loc AnimationKeyframe.PrevFrame}"  Click="{s:MethodBinding PrevFrame}"   Margin="2,0,2,0"/>
            <Button Grid.Column="2" Content="{loc:Loc AnimationKeyframe.NextFrame}"  Click="{s:MethodBinding NextFrame}"   Margin="2,0,0,0"/>
            <Button Grid.Column="3" Content="{loc:Loc AnimationKeyframe.LastFrame}"  Click="{s:MethodBinding LastFrame}"   Margin="2,0,0,0"/>
        </Grid>
        
        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{loc:Loc AnimationKeyframe.SelectFrameA}"  Click="{s:MethodBinding SelectFrameAInterpolation}" Margin="0,0,2,0"/>
            <Button Grid.Column="1" Content="{loc:Loc AnimationKeyframe.SelectFrameB}"  Click="{s:MethodBinding SelectFrameBInterpolation}" Margin="2,0,2,0"/>
            <Button Grid.Column="2" Content="{loc:Loc AnimationKeyframe.ApplyInterpolationCurrent}"  Click="{s:MethodBinding ApplyInterpolationOnCurrentFrame}" Margin="2,0,0,0"/>
            <Button Grid.Column="3" Content="{loc:Loc AnimationKeyframe.ApplyInterpolationAcross}"  Click="{s:MethodBinding ApplyInterpolationAcrossFrames}" Margin="2,0,0,0"/>
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel>
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.LivePreviewInterpolation}" IsChecked="{Binding PreviewInterpolation, UpdateSourceTrigger=PropertyChanged}"  />
                <CheckBox DockPanel.Dock="Top" Content="{loc:Loc AnimationKeyframe.InterpolationOnlySelectedBones}" IsChecked="{Binding InterpolationOnlyOnSelectedBones, UpdateSourceTrigger=PropertyChanged}"  />
            </DockPanel>
        </Grid>
        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="{loc:Loc Common.Reset}"  Click="{s:MethodBinding ResetInterpolationSlider}" Margin="2,0,0,0"/>
            <Slider Grid.Column="1" Minimum="0" Maximum="1" TickFrequency="0.1" Value="{Binding InterpolationValue, UpdateSourceTrigger=PropertyChanged}" IsSnapToTickEnabled="true" TickPlacement="BottomRight" >
                <Slider.LayoutTransform>
                    <ScaleTransform ScaleX="2" ScaleY="2"/>
                </Slider.LayoutTransform>
            </Slider>
        </Grid>

        <Grid DockPanel.Dock="Top" Margin="5,5,5,0">
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />
        </Grid>

        <Button DockPanel.Dock="Top" Margin="5" Content="{loc:Loc SettingsWindow.SaveButton}" Click="{s:MethodBinding Save}"/>
        <Button DockPanel.Dock="Top" Margin="5" Content="{loc:Loc Common.SaveAs}" Click="{s:MethodBinding SaveAs}"/>

    </DockPanel>
</UserControl>
