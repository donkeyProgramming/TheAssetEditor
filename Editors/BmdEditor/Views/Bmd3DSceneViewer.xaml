<UserControl x:Class="Editors.BmdEditor.Views.Bmd3DSceneViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:wpf="clr-namespace:GameWorld.Core.WpfWindow;assembly=GameWorld.Core"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <!-- 3D Scene Viewer - bind to Scene property like working editors -->
        <ContentControl Content="{Binding Scene, Mode=OneTime}" />
        
        <!-- Overlay for scene information -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Top" 
                Background="#80000000" Padding="10" Margin="5"
                CornerRadius="5">
            <StackPanel>
                <TextBlock Text="BMD 3D Scene" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Use mouse to orbit, scroll to zoom" Foreground="LightGray" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
